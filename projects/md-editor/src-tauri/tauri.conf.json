{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyMD",
  "identifier": "com.mymd.app",
  "version": "1.0.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyMD — 跨平台 Markdown 编辑器",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "backgroundColor": "#0D0D0D"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://cdnjs.cloudflare.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "MyMD Team",
    "shortDescription": "跨平台 Markdown 编辑器",
    "longDescription": "MyMD 是一款面向产品经理和专业写作者的 Markdown 编辑器，支持即时渲染、代码高亮、Mermaid 图表、多格式导出。",
    "category": "Productivity",
    "windows": {
      "digestAlgorithm": "sha256",
      "wix": null,
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}